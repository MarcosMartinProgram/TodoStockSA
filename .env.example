# Copiar este archivo como .env y completar los valores

# Puerto del servidor (opcional, default: 3000)
PORT=3000

# URI de conexión a MongoDB
# Ejemplo local:  mongodb://localhost:27017/todostock
# Ejemplo Atlas:  mongodb+srv://usuario:password@cluster.mongodb.net/todostock
MONGODB_ATLAS_URI=mongodb://localhost:27017/todostock

# Credenciales de acceso al sistema
LOGIN_USUARIO=admin
LOGIN_PASSWORD=admin123

# Entorno de ejecución
NODE_ENV=development

# Clave secreta para la generación de tokens JWT
JWT_SECRET=TodostockJWT2026