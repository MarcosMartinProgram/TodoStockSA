doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Ingresar | TodoStock S.A.
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet")
    style.
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :root {
        --bg: #f5f0e8;
        --ink: #172127;
        --muted: #5f6a6f;
        --line: rgba(23, 33, 39, 0.12);
        --brand: #0d9488;
        --brand-deep: #0f766e;
        --accent: #f97316;
        --danger: #d9485f;
        --panel: rgba(255, 252, 247, 0.92);
        --shadow-lg: 0 24px 60px rgba(30, 41, 59, 0.16);
      }
      body {
        font-family: 'Manrope', sans-serif;
        background:
          radial-gradient(circle at top left, rgba(13, 148, 136, 0.18), transparent 26%),
          radial-gradient(circle at 85% 18%, rgba(249, 115, 22, 0.16), transparent 20%),
          linear-gradient(180deg, #f8f5ef 0%, #f5efe7 42%, #efe7dc 100%);
        color: var(--ink);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image: linear-gradient(rgba(23, 33, 39, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(23, 33, 39, 0.03) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: linear-gradient(180deg, rgba(0,0,0,0.55), transparent 92%);
      }
      .login-wrap {
        width: 100%;
        max-width: 440px;
        padding: 24px;
        position: relative;
        z-index: 1;
      }
      .login-brand {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 32px;
        justify-content: center;
      }
      .brand-icon {
        width: 52px;
        height: 52px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-family: 'Space Grotesk', sans-serif;
        font-weight: 700;
        font-size: 1.1rem;
        color: white;
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
        box-shadow: 0 18px 35px rgba(15, 118, 110, 0.28);
      }
      .brand-copy small {
        display: block;
        color: var(--muted);
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 2px;
      }
      .brand-copy strong {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.2rem;
      }
      .login-card {
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.62);
        box-shadow: var(--shadow-lg);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 38px 36px;
      }
      .login-card h2 {
        font-family: 'Space Grotesk', sans-serif;
        font-size: 1.5rem;
        margin-bottom: 6px;
      }
      .login-card .sub {
        color: var(--muted);
        font-size: 0.93rem;
        margin-bottom: 28px;
      }
      .form-group {
        margin-bottom: 18px;
      }
      .form-group label {
        display: block;
        margin-bottom: 7px;
        font-weight: 800;
        font-size: 0.92rem;
        color: var(--ink);
      }
      .form-group input {
        width: 100%;
        padding: 14px 16px;
        border: 1px solid rgba(23, 33, 39, 0.12);
        border-radius: 16px;
        font-size: 1rem;
        font-family: 'Manrope', sans-serif;
        background: rgba(255, 255, 255, 0.74);
        color: var(--ink);
        transition: border-color 0.18s, outline 0.18s;
      }
      .form-group input:focus {
        outline: 2px solid rgba(13, 148, 136, 0.18);
        border-color: rgba(13, 148, 136, 0.32);
      }
      .btn-login {
        width: 100%;
        padding: 15px;
        border-radius: 999px;
        border: none;
        cursor: pointer;
        font-family: 'Manrope', sans-serif;
        font-size: 1rem;
        font-weight: 800;
        color: #fff9f2;
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-deep) 100%);
        box-shadow: 0 18px 30px rgba(15, 118, 110, 0.22);
        margin-top: 8px;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }
      .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 24px 38px rgba(15, 118, 110, 0.3);
      }
      .alert-error {
        background: rgba(244, 63, 94, 0.09);
        color: #9f1239;
        border: 1px solid rgba(225, 29, 72, 0.12);
        border-radius: 14px;
        padding: 13px 16px;
        font-size: 0.92rem;
        font-weight: 600;
        margin-bottom: 20px;
      }

  body
    .login-wrap
      .login-brand
        span.brand-icon TS
        span.brand-copy
          small Distribuidora mayorista
          strong TodoStock S.A.

      .login-card
        h2 Bienvenido
        p.sub Ingresá tus credenciales para continuar.

        if error
          .alert-error #{error}

        form(action="/login" method="POST")
          .form-group
            label(for="usuario") Usuario
            input#usuario(type="text" name="usuario" placeholder="Ingresá tu usuario" autocomplete="username" required)
          .form-group
            label(for="password") Contraseña
            input#password(type="password" name="password" placeholder="••••••••" autocomplete="current-password" required)
          button.btn-login(type="submit") Ingresar al sistema
