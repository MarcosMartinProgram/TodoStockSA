extends ../layout

block content
  section.section-banner
    .section-copy
      span.eyebrow Alta comercial
      h2 Nuevo proveedor
      p.
        Incorpore una empresa proveedora con sus datos de contacto para sostener el circuito de compras y reposición.
      .kpi-row
        span.chip Contacto directo
        span.chip Datos centralizados
        span.chip Base comercial
    .section-media(style="background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=1200&q=80');")

  .top-bar
    p.muted Registre la empresa y su persona de contacto para integrarla a la red de abastecimiento.
    a.btn.btn-primary(href="/proveedores") Volver al listado

  .card
    form(action="/proveedores" method="POST")
      .form-group
        label(for="nombre") Nombre de la empresa *
        input#nombre(type="text" name="nombre" required placeholder="Ej: Limpieza Total S.R.L.")

      .form-group
        label(for="contacto") Persona de contacto *
        input#contacto(type="text" name="contacto" required placeholder="Ej: Juan Pérez")

      .form-group
        label(for="telefono") Teléfono *
        input#telefono(type="text" name="telefono" required placeholder="Ej: 011-4555-1234")

      .form-group
        label(for="email") Email *
        input#email(type="email" name="email" required placeholder="Ej: ventas@empresa.com")

      .form-group
        label(for="direccion") Dirección
        input#direccion(type="text" name="direccion" placeholder="Ej: Av. Corrientes 1234, CABA")

      button.btn.btn-success(type="submit") Crear Proveedor
