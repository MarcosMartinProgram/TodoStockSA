extends ../layout

block content
  .form-container
    h2 Registrar Pago
    form(action="/pagos" method="POST")
      .form-group
        label(for="clienteId") Cliente *
        select#clienteId(name="clienteId" required)
          option(value="") Seleccione un cliente...
          each cliente in clientes
            option(value=cliente.id selected=(clienteIdPresel && clienteIdPresel === cliente.id)) #{cliente.nombre} (#{cliente.cuit})
      .form-group
        label(for="fecha") Fecha *
        input#fecha(type="date" name="fecha" required)
      .form-group
        label(for="importe") Importe *
        input#importe(type="number" name="importe" required min="0.01" step="0.01" placeholder="0.00")
      .form-group
        label(for="medioPago") Medio de Pago *
        select#medioPago(name="medioPago" required)
          option(value="efectivo") Efectivo
          option(value="transferencia") Transferencia
          option(value="cheque") Cheque
          option(value="tarjeta") Tarjeta
          option(value="otro") Otro
      .form-group
        label(for="observaciones") Observaciones
        input#observaciones(type="text" name="observaciones" placeholder="Opcional")
      .form-actions
        button.btn.btn-success(type="submit") Registrar Pago
        a.btn(href="/pagos") Cancelar
