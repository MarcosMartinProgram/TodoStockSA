extends ../layout

block content
  .form-container
    h2 Editar Pago
    form(action=`/pagos/${pago.id}?_method=PUT` method="POST")
      .form-group
        label Cliente
        input(type="text" disabled value=(pago.clienteId ? pago.clienteId.nombre : '-'))
      .form-group
        label(for="fecha") Fecha *
        input#fecha(type="date" name="fecha" required value=new Date(pago.fecha).toISOString().split('T')[0])
      .form-group
        label(for="importe") Importe *
        input#importe(type="number" name="importe" required min="0.01" step="0.01" value=pago.importe)
      .form-group
        label(for="medioPago") Medio de Pago *
        select#medioPago(name="medioPago" required)
          option(value="efectivo" selected=(pago.medioPago === 'efectivo')) Efectivo
          option(value="transferencia" selected=(pago.medioPago === 'transferencia')) Transferencia
          option(value="cheque" selected=(pago.medioPago === 'cheque')) Cheque
          option(value="tarjeta" selected=(pago.medioPago === 'tarjeta')) Tarjeta
          option(value="otro" selected=(pago.medioPago === 'otro')) Otro
      .form-group
        label(for="observaciones") Observaciones
        input#observaciones(type="text" name="observaciones" value=pago.observaciones)
      .form-actions
        button.btn.btn-success(type="submit") Guardar Cambios
        a.btn(href="/pagos") Cancelar
