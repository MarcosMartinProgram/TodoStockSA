extends ../layout

block content
  .top-bar
    h2 Nuevo Producto
    a.btn.btn-primary(href="/productos") Volver al listado

  .card
    form(action="/productos" method="POST")
      .form-group
        label(for="nombre") Nombre *
        input#nombre(type="text" name="nombre" required placeholder="Ej: Lavandina Concentrada x 5L")

      .form-group
        label(for="descripcion") Descripción
        textarea#descripcion(name="descripcion" placeholder="Descripción del producto...")

      .form-group
        label(for="precio") Precio *
        input#precio(type="number" name="precio" step="0.01" min="0" required placeholder="0.00")

      .form-group
        label(for="stock") Stock *
        input#stock(type="number" name="stock" min="0" required placeholder="0")

      .form-group
        label(for="proveedorId") Proveedor *
        select#proveedorId(name="proveedorId" required)
          option(value="" disabled selected) Seleccione un proveedor
          each prov in proveedores
            option(value=prov.id) #{prov.nombre}

      button.btn.btn-success(type="submit") Crear Producto
