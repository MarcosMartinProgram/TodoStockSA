extends ../layout

block content
  section.section-banner
    .section-copy
      span.eyebrow Ficha de producto
      h2 Detalle del producto
      p.
        Consulte la información operativa del artículo y su relación con el proveedor desde una vista más legible.
      .kpi-row
        span.chip Precio vigente
        span.chip Stock visible
        span.chip Proveedor asociado
    .section-media(style="background-image: url('https://images.unsplash.com/photo-1585421514738-01798e348b17?auto=format&fit=crop&w=1200&q=80');")

  .top-bar
    p.muted Revise la ficha completa antes de editar o eliminar el registro.
    a.btn.btn-primary(href="/productos") Volver al listado

  .card
    .detail-grid
      dt ID
      dd #{producto.id}
      dt Nombre
      dd #{producto.nombre}
      dt Descripción
      dd #{producto.descripcion || 'Sin descripción'}
      dt Precio
      dd $#{producto.precio.toFixed(2)}
      dt Stock
      dd #{producto.stock} unidades
      dt Proveedor
      dd
        if producto.proveedorId
          a(href=`/proveedores/${producto.proveedorId.id}`) #{producto.proveedorId.nombre}
          |  (#{producto.proveedorId.contacto} - #{producto.proveedorId.telefono})
        else
          em Sin proveedor asignado

  .actions
    a.btn.btn-warning(href=`/productos/${producto.id}/editar`) Editar
    form.inline(action=`/productos/${producto.id}?_method=DELETE` method="POST")
      button.btn.btn-danger(type="submit" onclick="return confirm('¿Está seguro?')") Eliminar
