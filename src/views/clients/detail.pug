extends ../layout

block content
  .detail-header
    div
      h2 #{cliente.nombre}
      p.muted CUIT: #{cliente.cuit} &nbsp;|&nbsp; #{cliente.condicionIva.replace(/_/g, ' ')}
    .actions
      a.btn.btn-warning(href=`/clientes/${cliente.id}/editar`) Editar
      form.inline(action=`/clientes/${cliente.id}?_method=DELETE` method="POST")
        button.btn.btn-danger(type="submit" onclick="return confirm('¿Eliminar este cliente?')") Eliminar

  .data-panel(style="margin-bottom: 1.5rem")
    .detail-grid
      .detail-item
        span.label Email
        span.value #{cliente.email}
      .detail-item
        span.label Teléfono
        span.value #{cliente.telefono || '-'}
      .detail-item
        span.label Dirección
        span.value #{cliente.direccion || '-'}
      .detail-item
        span.label Saldo actual
        span.value(class=(saldo > 0 ? 'text-danger' : saldo < 0 ? 'text-success' : ''))
          | $#{Math.abs(saldo).toFixed(2)} #{saldo > 0 ? '(deuda)' : saldo < 0 ? '(a favor)' : '(sin saldo)'}

  .top-bar
    p.muted Operaciones del cliente
    div(style="display:flex;gap:0.5rem")
      a.btn.btn-success(href=`/comprobantes/crear?clienteId=${cliente.id}`) + Comprobante
      a.btn.btn-success(href=`/pagos/crear?clienteId=${cliente.id}`) + Pago
      a.btn.btn-primary(href=`/cuenta/${cliente.id}`) Ver Cuenta Corriente
